{
  "name": "@d13co/escreg",
  "version": "0.0.1",
  "description": "CLI for the Escreg on-chain escrow registry on Algorand",
  "main": "dist/index.js",
  "bin": {
    "escreg": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "npm run build:ts",
    "build": "npm run build:ts && npm run build:executables",
    "build:ts": "tsc",
    "build:executables": "bun run build-executables.ts",
    "build:linux-amd64": "bun run build-linux-amd64.ts",
    "build:docker": "bun run build-docker.ts",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^9.0.0",
    "@d13co/escreg-sdk": "^0.0.3",
    "algosdk": "^3.0.0",
    "dotenv": "^16.3.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "@types/yargs": "^17.0.32",
    "@vitest/coverage-v8": "^2.1.8",
    "concurrently": "^9.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d13co/escreg.git",
    "directory": "projects/client"
  },
  "homepage": "https://github.com/d13co/escreg#cli",
  "bugs": {
    "url": "https://github.com/d13co/escreg/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "algorand",
    "escrow",
    "registry",
    "cli"
  ],
  "author": "Tasos Bitsios",
  "license": "ISC"
}
